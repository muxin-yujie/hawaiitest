                                        border-radius: 6px; font-size: 0.65em; text-align: center;
                                        border: 1px solid #f5f5f5;"
                                 onmouseover="this.style.background='#fff5f8'; this.style.borderColor='#ffe4ec'; this.style.transform='translateY(-1px)'" 
                                 onmouseout="this.style.background='#fff'; this.style.borderColor='#f5f5f5'; this.style.transform='translateY(0)'">
                                <div style="font-size: 1.2em; margin-bottom: 2px;">🌿</div>
                                <div style="color: #666; font-weight: 700;">Branches</div>
                            </div>
                            <div style="padding: 6px 3px; background: #fff; 
                                        border-radius: 6px; font-size: 0.65em; text-align: center;
                                        border: 1px solid #f5f5f5;"
                                 onmouseover="this.style.background='#fff5f8'; this.style.borderColor='#ffe4ec'; this.style.transform='translateY(-1px)'" 
