<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🌺 language tour~ 阳光夏威夷 🌺</title>
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <!-- 背景音乐 -->
    <audio id="bgMusic1" preload="auto">
        <source src="music/wave.mp3" type="audio/mpeg">
    </audio>
    <audio id="bgMusic2" preload="auto">
        <source src="music/ipanema.mp3" type="audio/mpeg">
    </audio>
    <audio id="bgMusic3" preload="auto">
        <source src="music/red-blouse.mp3" type="audio/mpeg">
    </audio>
    
    <!-- 环境音效 -->
    <audio id="ambientOcean" loop preload="auto">
        <source src="music/ocean-ambient.mp3" type="audio/mpeg">
    </audio>
    <audio id="ambientAirport" loop preload="auto">
        <source src="music/airport-ambient.mp3" type="audio/mpeg">
    </audio>
    <audio id="ambientHotel" loop preload="auto">
        <source src="music/hotel-ambient.mp3" type="audio/mpeg">
    </audio>
    <audio id="ambientNature" loop preload="auto">
        <source src="music/nature-ambient.mp3" type="audio/mpeg">
    </audio>
    
    <div id="nameSetupPage" class="setup-page" style="display: none;">
        <div class="floating-elements">
            <div class="floating-element">👒</div>
            <div class="floating-element">🌊</div>
            <div class="floating-element">🌸</div>
            <div class="floating-element">🏄‍♀️</div>
            <div class="floating-element">🌺</div>
            <div class="floating-element">🌴</div>
            <div class="floating-element">☀️</div>
            <div class="floating-element">✨</div>
            <div class="floating-element">🌞</div>
            <div class="floating-element">🏖️</div>
            <div class="floating-element">🌼</div>
            <div class="floating-element">💫</div>
        </div>
        <div class="setup-container">
            <div class="setup-header">
                <h1>🌺 language tour~ 阳光夏威夷 🌺</h1>
                <p>沉浸式英语学习文字冒险游戏</p>
