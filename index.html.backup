                            </div>
                        </div>
                    </div>
                    
                    <!-- 帮助提示 -->
                    <div style="padding: 6px 10px; background: #fff8e1; 
                                border-top: 1px dashed #ffe0b2; font-size: 0.65em; color: #f57f17; text-align: center;">
                        💡 按 <b>💡 Help</b> 获取帮助
                    </div>
